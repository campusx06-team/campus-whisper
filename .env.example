# Campus Whisper — Environment Variables
# Copy this file to .env.local and fill in your Supabase credentials

# ═══════════════════════════════════════════════════════════
# SUPABASE CONFIG
# ═══════════════════════════════════════════════════════════

# Your Supabase project URL
# Get from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anonymous/public key
# Get from: Supabase Dashboard → Settings → API → Project API keys
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═══════════════════════════════════════════════════════════
# OPTIONAL: ADMIN / SERVER OPERATIONS
# (Do NOT expose these in client-side code!)
# ═══════════════════════════════════════════════════════════

# Your Supabase service key (for server-side admin operations)
# Get from: Supabase Dashboard → Settings → API → Service Role Key
# NEVER commit this to git, only use in .env.local
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ═══════════════════════════════════════════════════════════
# APP CONFIG
# ═══════════════════════════════════════════════════════════

# Environment (development, production)
VITE_ENV=development

# App URL (for email OTP redirects)
VITE_APP_URL=http://localhost:5173

# ═══════════════════════════════════════════════════════════
# OPTIONAL: THIRD-PARTY SERVICES
# ═══════════════════════════════════════════════════════════

# If using image uploads (e.g., Supabase Storage)
VITE_STORAGE_BUCKET=campus-whisper-images

# If using email service (e.g., SendGrid)
# SENDGRID_API_KEY=SG...

# If using analytics (e.g., Plausible)
# VITE_ANALYTICS_DOMAIN=campus-whisper.com

# ═══════════════════════════════════════════════════════════
# SETUP INSTRUCTIONS
# ═══════════════════════════════════════════════════════════

# 1. Create account at https://supabase.com
# 2. Create a new project
# 3. Go to Settings → API
# 4. Copy Project URL and paste in VITE_SUPABASE_URL
# 5. Copy anon/public key and paste in VITE_SUPABASE_ANON_KEY
# 6. Rename this file to .env.local
# 7. Never commit .env.local to git!
# 8. Run: npm install && npm run dev

# ═══════════════════════════════════════════════════════════
# SECURITY NOTES
# ═══════════════════════════════════════════════════════════

# - Only VITE_* variables are exposed to client-side code
# - SUPABASE_SERVICE_KEY should NEVER be in frontend code
# - Use VITE_* prefix for frontend variables
# - Add .env.local to .gitignore
# - Each developer should have their own .env.local
